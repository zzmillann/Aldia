        {
            "parameters": {
                "mode": "runOnceForAllItems",
                "language": "javaScript",
                "jsCode": "// Recibe dos inputs: Bokun (input 0) y Plantilla (input 1)\n// Estrategia: Set de booking_id de la plantilla => filtrado O(1)\n\nconst bokunItems = $('Leer Bokun (130k filas)').all();\nconst plantillaItems = $('Leer Plantilla (referencia)').all();\n\n// 1) Construimos el Set con los booking_id de la plantilla\nconst plantillaKeys = new Set();\nfor (const item of plantillaItems) {\n  const key = item.json.booking_id;\n  if (key !== undefined && key !== null && key !== '') {\n    // Normalizamos a string y sin espacios para evitar falsos negativos\n    plantillaKeys.add(String(key).trim());\n  }\n}\n\n// 2) Filtramos las filas de Bokun cuyo booking_id NO estÃ¡ en la plantilla\nconst nuevas = [];\nfor (const item of bokunItems) {\n  const key = item.json.booking_id;\n  if (key === undefined || key === null || key === '') continue; // descartar filas sin id\n  const keyNorm = String(key).trim();\n  if (!plantillaKeys.has(keyNorm)) {\n    nuevas.push({ json: item.json });\n  }\n}\n\nconsole.log(`Bokun: ${bokunItems.length} | Plantilla: ${plantillaItems.length} | Nuevas a insertar: ${nuevas.length}`);\n\nreturn nuevas;"
            },
